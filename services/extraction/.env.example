# Extraction worker config. Copy to .env (gitignored) and fill in. With no
# DATABASE_URL the worker idles gracefully instead of crashing.

# OpenAI — the extractor's brain
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-2024-08-06

# Supabase Postgres — direct connection (port 5432, NOT the 6543 pooler).
# The worker strips a ?pgbouncer=... param if present.
DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR-PROJECT.supabase.co:5432/postgres

# Supabase storage — to mint signed URLs for the paper PDFs the processor downloads
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Worker loop
POLL_INTERVAL=30
